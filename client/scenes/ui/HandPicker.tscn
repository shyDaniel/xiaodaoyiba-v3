; S-370 §H2.4 — Stardew-quality carved-wood button styling. The default
; Godot Button look is a flat dark-rounded-rectangle that breaks the
; rustic painterly read. We swap normal/hover/pressed/focus styles for a
; 9-slice StyleBoxTexture using wood_button_9slice.png so each button
; reads as a hand-carved wooden tile. hover modulates with a warm tint;
; pressed swaps to the inverted-carve PNG so the button visibly indents.
[sub_resource type="StyleBoxTexture" id="btn_normal"]
texture = ExtResource("3_wood")
texture_margin_left = 16.0
texture_margin_top = 16.0
texture_margin_right = 16.0
texture_margin_bottom = 16.0
content_margin_left = 12.0
content_margin_top = 8.0
content_margin_right = 12.0
content_margin_bottom = 8.0

[sub_resource type="StyleBoxTexture" id="btn_hover"]
texture = ExtResource("3_wood")
texture_margin_left = 16.0
texture_margin_top = 16.0
texture_margin_right = 16.0
texture_margin_bottom = 16.0
content_margin_left = 12.0
content_margin_top = 8.0
content_margin_right = 12.0
content_margin_bottom = 8.0
modulate_color = Color(1.16, 1.10, 0.94, 1)

[sub_resource type="StyleBoxTexture" id="btn_pressed"]
texture = ExtResource("4_wood_pressed")
texture_margin_left = 16.0
texture_margin_top = 16.0
texture_margin_right = 16.0
texture_margin_bottom = 16.0
content_margin_left = 12.0
