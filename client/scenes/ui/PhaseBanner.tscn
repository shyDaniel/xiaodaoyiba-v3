[gd_scene load_steps=3 format=3 uid="uid://bxdyb_phasebanner_v1"]

[ext_resource type="Texture2D" path="res://assets/sprites/ui/wood_panel_9slice.png" id="1_wood"]

; S-370 §H2.4 — PhaseBanner extracted into its own scene with a 9-slice
; carved-wood StyleBoxTexture. Old version was a Panel + StyleBoxFlat
; dark-rounded-rectangle that read as default-Godot, breaking the
; Stardew-quality painterly product surface. The 16-px texture margins
; match wood_panel_9slice.png's carved frame, so corners never stretch
; and the rim stays crisp at any panel size.
[sub_resource type="StyleBoxTexture" id="bg_phase"]
texture = ExtResource("1_wood")
texture_margin_left = 16.0
texture_margin_top = 16.0
texture_margin_right = 16.0
texture_margin_bottom = 16.0
content_margin_left = 18.0
content_margin_top = 8.0
content_margin_right = 18.0
content_margin_bottom = 8.0
modulate_color = Color(1, 1, 1, 0.97)

[node name="PhaseBanner" type="PanelContainer"]
