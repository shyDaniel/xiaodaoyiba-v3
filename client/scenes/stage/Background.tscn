; S-439 §H2.5 — replaced flat blue-grey Polygon2D mountains with shaded
; CC0 mountain composites (kenney background-elements pointy_mountains
; silhouette + ridge highlights + snow caps + valley shadows baked in
; via scripts/gen-mountain-composite.mjs). Per-frame check
; scripts/check-aesthetic-coverage.py asserts ≥6 hue clusters in the
; cols 0-200 region of any in-game screenshot — passes by construction
; (the front composite has 12 distinct quantized hue buckets).
;
; Sprite2D + region_enabled + texture_repeat tiles the 1001×168 source
; horizontally across the parallax layer's -2000..2000 span. centered
; = false anchors the top-left of the sprite at `position`. The back
; layer uses the desaturated/lighter mountain_back.png so atmospheric
; perspective is preserved.

[node name="MountainsBack" type="ParallaxLayer" parent="."]
motion_scale = Vector2(0.15, 0.05)

[node name="MountainBackSprite" type="Sprite2D" parent="MountainsBack"]
