; --- Themed background — same palette as Landing.tscn / Background.tscn so
; --- the lobby→game transition feels continuous (S-327 §C11). The sky +
; --- mountains + grass are painted directly via Control children rather
; --- than ParallaxBackground because the lobby has no scrolling camera.

[node name="Sky" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.50, 0.68, 0.82, 1)

[node name="SkyHorizon" type="ColorRect" parent="."]
layout_mode = 1
offset_left = 0.0
offset_top = 200.0
offset_right = 1280.0
offset_bottom = 320.0
color = Color(0.95, 0.78, 0.55, 0.40)

[node name="MountainsBack" type="Polygon2D" parent="."]
