; Grass-row darker stripe at the seam so the foreground reads as ground,
; not a flat block (matches Game.tscn's hill-line accent at y≈0.58vh).
[node name="GrassRidge" type="ColorRect" parent="."]
layout_mode = 1
anchor_top = 0.58
anchor_right = 1.0
offset_top = 0.0
offset_bottom = 6.0
color = Color(0.22, 0.40, 0.28, 1)

; --- Title — Chinese nursery-rhyme couplet that the product is named
; --- after. Kept as actual CJK text so the label-node substring contract
; --- is satisfied; a Latin transliteration sits underneath so the lobby
; --- still reads in browsers without a system CJK font fallback.
[node name="Title" type="VBoxContainer" parent="."]
layout_mode = 1
offset_left = 60.0
offset_top = 50.0
offset_right = 1220.0
offset_bottom = 200.0
theme_override_constants/separation = 4

[node name="RhymeLine1" type="Label" parent="Title"]
text = "小刀一把，来到你家"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 44
theme_override_colors/font_color = Color(1, 0.94, 0.62, 1)
theme_override_colors/font_outline_color = Color(0.06, 0.07, 0.1, 1)
theme_override_constants/outline_size = 8

[node name="RhymeLine2" type="Label" parent="Title"]
text = "扒你裤衩，直接咔嚓！"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 44
theme_override_colors/font_color = Color(1, 0.94, 0.62, 1)
theme_override_colors/font_outline_color = Color(0.06, 0.07, 0.1, 1)
theme_override_constants/outline_size = 8

[node name="RhymeLatin" type="Label" parent="Title"]
text = "One little knife, comes to your door — pulls down your pants, CHOP!"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 18
theme_override_colors/font_color = Color(0.95, 0.95, 0.95, 1)
theme_override_colors/font_outline_color = Color(0.06, 0.07, 0.1, 1)
theme_override_constants/outline_size = 4

; --- Knife sprite — re-uses SpriteAtlas.knife_texture; Lobby.gd sets
; --- texture + idle bob tween on _ready(). Anchored top-center between
; --- the rhyme couplet and the houses. Fallback: a Polygon2D shape is
; --- drawn behind it so a screenshot in the unlikely SpriteAtlas-missing
; --- case still shows a blade silhouette.
[node name="KnifeAnchor" type="Node2D" parent="."]
position = Vector2(640, 230)

[node name="KnifeShadow" type="Polygon2D" parent="KnifeAnchor"]
position = Vector2(0, 32)
color = Color(0, 0, 0, 0.30)
polygon = PackedVector2Array(-72, 0, 72, 0, 60, 6, -60, 6)

[node name="Knife" type="Sprite2D" parent="KnifeAnchor"]
centered = true
scale = Vector2(2.4, 2.4)
rotation = -0.35

; --- House row — three sample iso houses behind the player list, tinted
; --- in three distinct roof palettes so the §C11 "≥3 distinct house
; --- color schemes" gate is met at the lobby viewport already. Lobby.gd
; --- assigns SpriteAtlas.house_textures[0] + per-instance modulate.
[node name="HouseRow" type="Node2D" parent="."]
position = Vector2(880, 560)

[node name="HouseLeft" type="Node2D" parent="HouseRow"]
position = Vector2(-220, 20)

[node name="Sprite" type="Sprite2D" parent="HouseRow/HouseLeft"]
centered = true
scale = Vector2(0.85, 0.85)

[node name="HouseCenter" type="Node2D" parent="HouseRow"]
position = Vector2(0, -10)

[node name="Sprite" type="Sprite2D" parent="HouseRow/HouseCenter"]
centered = true
scale = Vector2(1.05, 1.05)

[node name="HouseRight" type="Node2D" parent="HouseRow"]
position = Vector2(220, 20)

[node name="Sprite" type="Sprite2D" parent="HouseRow/HouseRight"]
centered = true
scale = Vector2(0.85, 0.85)

; --- Lobby card — the admin/control surface. Smaller and lower so the
; --- themed background reads through. The previous version's 520×520
; --- panel covered ~50% of the viewport; this one is 460×360 anchored
; --- bottom-left so the rhyme + knife + houses dominate.
[node name="Card" type="PanelContainer" parent="."]
